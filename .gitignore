# Environment
.env
.env.db
.env.local
.env.*.local
.env.dev

# Runtime secrets — written by run.sh's write_secrets() (chmod 600).
# Never commit: each host generates its own on first start.
.secrets/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/

# Node
node_modules/
npm-debug.log*
frontend/build/
frontend/.next/

# Audio (generated TTS MP3s — persistent CMS working dir, NOT in the db image's
# build context. dev/prod both read audio from the `shared_audio` named volume
# which the content-baked db image seeds on first start. db/.dockerignore
# excludes this from the docker build context so it doesn't bloat the image.)
db/audio/

# db-image build inputs — populated by scripts/ops/db/bake_image.sh build.
# Only the Dockerfile + init/99-audio.sh + README.md are committed.
db/init/01-content.sql
db/seed/

# Container-runtime stamps — written by frontend/entrypoint.sh so the
# hash-aware npm install can skip on no-op restarts. backend doesn't
# write one (deps are baked into the image at build time).
**/.package-lock.sha256

# bake staging
.bake-staging/

# Test artifacts (used by the test path that exercises the labels-read
# path in dev/prod build_image.sh — not normally created in real use)
.db-image-build/
.audio/

# Logs
*.log
logs/

# compose-watch runtime artifacts (PID + log written by run.sh when it
# auto-spawns the foreground watch process in background after `start`).
.compose-frontend-watch.pid
.compose-frontend-watch.log

# Stitch (Google Labs design tool) — local snapshot scratch.
# Generated by stitch-skills plugin when generating screens / capturing
# design tokens; never part of the app source.
.stitch/