FROM python:3.11-slim

# Project version (root ./VERSION, resolved by scripts/lib.sh) + git SHA.
ARG APP_VERSION=latest
ARG GIT_SHA=unknown
LABEL type-any-language.app.version="${APP_VERSION}"
LABEL type-any-language.app.git-sha="${GIT_SHA}"

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY entrypoint.sh ./
COPY . .

EXPOSE 8000

# entrypoint.sh runs at start; currently a no-op (just execs the CMD)
# but kept wired up so frontend/entrypoint.sh parity is preserved and
# future pre-start hooks have a place to go.
ENTRYPOINT ["sh", "./entrypoint.sh"]
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]