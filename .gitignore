# Environment
.env
.env.local
.env.*.local
.env.dev

# Runtime secrets — written by run.sh's write_secrets() (chmod 600).
# Never commit: each host generates its own on first start.
.secrets/

# Per-call artifact download dir used by scripts/secrets/fetch_secrets.sh.
# Bound to the script's lifetime via `trap rm -rf RETURN`, but the
# ignore entry is belt-and-suspenders against a crash mid-fetch.
/.fetch-*

# Dev-only per-branch state (cloud-db era, mode 2 per-branch dbs).
# .dev/ is gitignored wholesale even though it's currently mostly
# empty — `.dev/dev-db-name` is no longer written by bootstrap_tencent.sh
# (render_db_name derives from git branch every time). Kept as a
# directory gitignore in case future per-host state lands here again.
.dev/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/

# Node
node_modules/
npm-debug.log*

# Logs
*.log
logs/

# compose-watch runtime artifacts (PID + log written by run.sh when it
# auto-spawns the foreground watch process in background after `start`).
.compose-frontend-watch.pid
.compose-frontend-watch.log

# Stitch (Google Labs design tool) — local snapshot scratch.
# Generated by stitch-skills plugin when generating screens / capturing
# design tokens; never part of the app source.
.stitch/

.env.db
