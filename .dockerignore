# Root .dockerignore — defensive only.
# No current service uses `context: .`; per-service .dockerignore files
# (see backend/.dockerignore, frontend/.dockerignore) handle the real
# build contexts. This file guards against future root-context builds
# (e.g. a CI image) accidentally baking in secrets, VCS history, or
# editor state.

# VCS
.git
.gitignore
.gitattributes

# Secrets — never bake into any image
.env
.env.*
!.env.example.runtime
!.env.example.cms

# Editor / IDE / OS
.idea
.vscode
.claude
.DS_Store
Thumbs.db
*.swp
*.swo
