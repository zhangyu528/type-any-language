# Environment
.env
.env.local
.env.*.local
.env.dev

# Runtime secrets — written by run.sh's write_secrets() (chmod 600).
# Never commit: each host generates its own on first start.
.secrets/

# Per-call artifact download dir used by scripts/secrets/fetch_secrets.sh.
# Bound to the script's lifetime via `trap rm -rf RETURN`, but the
# ignore entry is belt-and-suspenders against a crash mid-fetch.
/.fetch-*

# Dev-only per-host state. The `.dev/` directory holds machine-local
# data that's never committed:
#   - .dev/data/postgres/  — bind-mounted postgres data dir (created
#                             on first `docker compose up` of the db
#                             service). Persistent across container
#                             restarts. Operator-backup-friendly
#                             (it's just a directory).
#   - .dev/dev-db-name      — written by bootstrap_tencent.sh in the
#                             mode-2 (per-branch) era; no longer
#                             written. Kept here in case it's still
#                             present on legacy hosts.
# future per-host state lands under .dev/.
.dev/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/

# Node
node_modules/
npm-debug.log*

# Logs
*.log
logs/

# compose-watch runtime artifacts (PID + log written by run.sh when it
# auto-spawns the foreground watch process in background after `start`).
.compose-frontend-watch.pid
.compose-frontend-watch.log

# Stitch (Google Labs design tool) — local snapshot scratch.
# Generated by stitch-skills plugin when generating screens / capturing
# design tokens; never part of the app source.
.stitch/

.env.db
