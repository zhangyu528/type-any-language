# Environment
.env
.env.local
.env.*.local
.env.dev

# Runtime secrets — written by run.sh's write_secrets() (chmod 600).
# Never commit: each host generates its own on first start.
.secrets/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/

# Node
node_modules/
npm-debug.log*

# bake staging
.bake-staging/

# db image build inputs — populated by scripts/ops/cms/bake_image.sh
# (which delegates to db/builder.py). Only the Dockerfile +
# init/01-content.sql are committed; 01-content.sql is regenerated on
# every bake from a fresh pg_dump and would just bloat the repo.
db/init/01-content.sql
# db/seed/ is no longer used (audio moved to COS in this release). Kept
# here as a guard rail in case future bake work reintroduces local audio.
db/seed/

# Test artifacts (used by the test path that exercises the labels-read
# path in dev/prod build_image.sh — not normally created in real use)
.db-image-build/
.audio/

# Logs
*.log
logs/

# compose-watch runtime artifacts (PID + log written by run.sh when it
# auto-spawns the foreground watch process in background after `start`).
.compose-frontend-watch.pid
.compose-frontend-watch.log

# Stitch (Google Labs design tool) — local snapshot scratch.
# Generated by stitch-skills plugin when generating screens / capturing
# design tokens; never part of the app source.
.stitch/