# Environment
.env
.env.db
.env.local
.env.*.local

# Runtime secrets — written by run.sh's write_secrets() (chmod 600).
# Never commit: each host generates its own on first start.
.secrets/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Docker
.docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
.pytest_cache/

# Node
node_modules/
npm-debug.log*
frontend/build/
frontend/.next/

# Audio (generated TTS MP3s — staging area for bake.sh, NOT bind-mounted
# at runtime. dev/prod both read audio from the `shared_audio` named volume
# which the content-baked db image seeds on first start.)
audio/

# db-image build inputs — populated by scripts/ops/db/bake_image.sh build.
# Only the Dockerfile + init/99-audio.sh + README.md are committed.
db/init/01-content.sql
db/seed/

# bake staging
.bake-staging/

# Test artifacts (used by the test path that exercises the labels-read
# path in dev/prod build_image.sh — not normally created in real use)
.db-image-build/
.audio/

# Logs
*.log
logs/