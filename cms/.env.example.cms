# CMS pipeline env — only needed on the host that runs content production.


#


# Init:        cp .env.example.cms cms/.env


#              # OR:  ./cms/scripts/env.sh    # idempotent, injects smart defaults


# Validate:    ./cms/scripts/env.sh doctor


#


# Consumed by: ./cms/scripts/staging.sh  (sync / sentences / audio / ...)


#              ./cms/scripts/bake_image.sh


# Not consumed by the backend container (pure read-layer; no AI / TTS at runtime).


#


# This file holds ONLY secrets + operator decisions. Everything else has a


# code-level default (POSTGRES_* / DATABASE_URL / DB_IMAGE / AUDIO_DIR /


# DEFAULT_BUCKET_TARGET_SIZE) and is overridden via shell env when needed:


#   POSTGRES_USER=foo ./cms/scripts/bake_image.sh


#   AUDIO_DIR=/my/audio/dir ./cms/scripts/staging.sh audio


#


# Full documentation: see CLAUDE.md → "Environment variables / CMS host"





# DATABASE_URL is NOT here — assembled at runtime from POSTGRES_PASSWORD + code defaults


# (POSTGRES_USER=english_user, POSTGRES_HOST=localhost, POSTGRES_PORT=5432,


#  POSTGRES_DB=english_learning). Set POSTGRES_PASSWORD via shell env or


#  copy .secrets/postgres_password from the dev/prod host.





# AI service (for `staging.sh sentences`)


# AI_API_KEY is the secret; AI_BASE_URL and AI_MODEL are operator decisions


# (e.g. swap to Azure / Anthropic, or upgrade gpt-3.5-turbo → gpt-4o) and


# therefore live here too. Defaults below are for the standard OpenAI setup.


AI_API_KEY=sk-your-real-api-key


AI_BASE_URL=https://api.openai.com/v1


AI_MODEL=gpt-3.5-turbo





# Audio / TTS (for `staging.sh audio`; TENCENT_* are required when running audio)


TENCENT_SECRET_ID=


TENCENT_SECRET_KEY=


TENCENT_APP_ID=0





# -----------------------------------------------------------------------------


# Cloud storage for binary assets (MP3s, future images/video)


# -----------------------------------------------------------------------------


# Default: write to local cms/.local/ (works for single-host CMS).


# Set CLOUD_PROVIDER=tencent_cos to upload to Tencent Cloud COS instead


# (multi-host CMS or production). When set, the CLOUD_BUCKET /


# CLOUD_REGION / CLOUD_ACCESS_KEY / CLOUD_SECRET_KEY fields are required


# (the pipeline aborts with a clear pointer to the missing keys otherwise).


# CLOUD_ENDPOINT is optional — set it to your COS custom domain or a


# CDN domain once you wire one up (used in sentence.audio_url).


#


# CLOUD_PROVIDER=local_fs


# CLOUD_BUCKET=english-content-12345


# CLOUD_REGION=ap-shanghai


# CLOUD_ACCESS_KEY=AKIDxxxxxxxxxxxxxxxxxxxxxxxx


# CLOUD_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# CLOUD_ENDPOINT=https://cdn.example.com


