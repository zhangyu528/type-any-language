# ---------------------------------------------------------------------------
# Runtime env — application-layer config consumed by docker-compose and
# the backend container. Init with:
#
#   cp .env.example.runtime .env
# OR:
#   ./scripts/prod/init.sh    # idempotent, injects smart defaults
#
# This file does NOT contain:
#   - AI / Tencent TTS keys (those live in .env.cms on the CMS host only)
#   - Database user / db-name (those come from the baked db image's labels)
#   - DOCKER_REGISTRY (when set, run.sh auto-pulls the latest baked image
#     on every start/restart — no env var needed)
#
# The backend (pydantic-settings) will refuse to start if any variable marked
# REQUIRED below is missing or left at its placeholder value — see
# `backend/app/config.py::_require_secrets`.
# ---------------------------------------------------------------------------

# =========================================================================
# Database (REQUIRED — password only)
# =========================================================================
# POSTGRES_USER and POSTGRES_DB are baked into the db image's labels at
# bake-time (see cms/bake_image.sh). prod/dev run.sh reads them via
# `docker inspect` and exports them to the compose env at start-time, so
# they are NOT configured here.
#
# The password is the one host-side secret: it stays on the host (never
# goes into the image) and is delivered to the postgres container via
# POSTGRES_PASSWORD_FILE → /run/secrets/postgres_password (chmod 600 on
# host). The backend reads DATABASE_URL_FILE → /run/secrets/database_url,
# which run.sh assembles from POSTGRES_PASSWORD + the labels.
#
# init.sh generates a random 24-char URL-safe value on first run.
# =========================================================================
POSTGRES_PASSWORD=change-me-postgres-password

# =========================================================================
# Security (REQUIRED)
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters and NOT the default placeholder below.
# init.sh generates a random 48-char URL-safe value on first run.
# =========================================================================
SECRET_KEY=change-me-in-production-must-be-at-least-32-chars-long

# =========================================================================
# CORS (REQUIRED)
# Comma-separated list of allowed browser origins.
# - Production:   ALLOWED_ORIGINS=http://your.domain
# - Local dev:    ALLOWED_ORIGINS=http://localhost,http://localhost:3000
# init.sh picks the right default for the role.
# =========================================================================
ALLOWED_ORIGINS=http://localhost
